# Copy this file to bin/.env and fill in your real values locally.
# Do not commit bin/.env to Git.

MONGO_URI=mongodb://172.28.0.10:27017/timetracking
MONGO_HOST=172.28.0.10
MONGO_PORT=27017
MONGO_DB_NAME=timetracking
MONGO_COLLECTION_NAME=devices

MQTT_BROKER=192.168.x.x
MQTT_PORT=1883
MQTT_TOPIC=miniserver/timetracking
MQTT_STATS_TOPIC=miniserver/timetracking/getstats
MQTT_PUB_TOPIC=loxberry/timetracking
MQTT_USERNAME=change-me
MQTT_PASSWORD=change-me

BACKEND_API=http://backend:5000/api/v1
INTERNAL_API_KEY=change-me-to-a-long-random-secret
INTERNAL_TRUSTED_SUBNETS=127.0.0.1/32,::1/128,172.17.0.0/16,172.28.0.0/16
MQTT_LOG_PAYLOADS=true

SECRET_KEY=change-me-to-a-random-flask-secret
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
FLASK_DEBUG=1
DOCKER_ENV=true

WEBAPP_BACKEND_URI=http://localhost:5000
